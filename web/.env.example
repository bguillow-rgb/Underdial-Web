# Copy to .env (or .env.local) and fill in. Astro reads PUBLIC_* vars at
# build time and exposes them through import.meta.env. None of these are
# secrets — they're public-by-design tokens that ship in the rendered HTML.
# Keep this file committed; never commit .env / .env.local with real values.

# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX
# Get from: https://analytics.google.com/ → Admin → Data Streams → Web → Stream Details
PUBLIC_GA4_ID=

# Google Search Console verification token
# Get from: https://search.google.com/search-console → Add property →
#   "HTML tag" verification → copy the content="..." value (NOT the meta tag)
PUBLIC_GSC_VERIFICATION=

# IndexNow key. Generate via scripts/generate-indexnow-key.sh
PUBLIC_INDEXNOW_KEY=
