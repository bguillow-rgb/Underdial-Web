---
import { SITE } from '../../consts';

// AboutPage schema completes the entity-anchor trio (Organization + Person
// + AboutPage) on /about. AI engines use this to confirm \u201Cwho is this site
// run by\u201D when deciding whether to cite.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `About | ${SITE.name}`,
  url: `${SITE.url}/about`,
  inLanguage: SITE.locale,
  mainEntity: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
