---
// Quick Answer block. The single most important AEO element on a content
// page: 40–60 words that directly answer the page\u2019s target query.
// Marked id="quick-answer" so Speakable schema (in ArticleSchema.astro)
// can point at it.
interface Props {
  text: string;
}
const { text } = Astro.props;
---
<section class="quick-answer" id="quick-answer">
  <span class="label">Quick Answer</span>
  <p>{text}</p>
</section>
